# ═══════════════════════════════════════════════════════════════
# LA REFINERÍA DIGITAL · Variables de entorno
# Copia este archivo como .env y completa los valores
# ═══════════════════════════════════════════════════════════════

# ── OBLIGATORIO ────────────────────────────────────────────────
# Tu API Key de Anthropic (conseguir en console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── REMOTION ──────────────────────────────────────────────────
# URL de tu servidor Remotion (local o Lambda)
REMOTION_API_URL=http://localhost:3001/api/render

# Para Remotion Lambda (AWS):
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# REMOTION_APP_REGION=us-east-1
# REMOTION_APP_FUNCTION_NAME=remotion-render-fn

# ── S3 (para guardar videos) ───────────────────────────────────
# S3_BUCKET=refineria-videos
# S3_REGION=us-east-1

# ── EMAIL (para entrega al cliente) ──────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=tu-app-password

# ── STRIPE (para pagos automáticos) ──────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── GOOGLE SHEETS (logging opcional) ─────────────────────────
# GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ── PEXELS (stock de videos) ─────────────────────────────────
# PEXELS_API_KEY=... (gratis en pexels.com/api)

# ── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
